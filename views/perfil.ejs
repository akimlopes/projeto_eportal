<!DOCTYPE html>
<html lang="pt-br">

<head>
    <link href='https://cdn.boxicons.com/fonts/basic/boxicons.min.css' rel='stylesheet'>
    <link rel="stylesheet" href="css/sidebar.css">
    <link rel="stylesheet" href="css/perfil.css">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Perfil</title>
</head>

<body class="sidebar-collapsed">
    <%- include('navbar') %>

        <div class="content perfil-content">
            <h1>Perfil</h1>
            <form class="perfil-grid" method="POST" action="">
                <!-- Card principal com avatar e dados básicos -->
                <div class="perfil-card">
                    <div class="perfil-avatar">
                        <img src="imgs/ETEC_POA.jpg" alt="Avatar do usuário" />
                    </div>
                    <div class="perfil-info">
                        <h2 ><%= user.Nome || 'Nome do usuário' %></h2>
                        <p>
                            Data de Nascimento:
                            <% if (user && user.Data_Nasc) { %>
                                <%= new Date(user.Data_Nasc).toLocaleDateString('pt-BR') %>
                            <% } else { %>
                                A definir
                            <% } %>
                        </p>
                        <p>RM: <%= user.ID_Alunos || user.ID_Professores || user.ID_Coordenadores %></p>
                        <p>Sexo: <%= user.Sexo %></p>
                    </div>
                </div>
                <!-- Card de contato -->
                <div class="perfil-card">
                    <h3>Contato</h3>
                    <input type="email" id="email" name="email" class="input-perfil" value="<%= user.Email %>"
                        disabled />
                    <input type="text" id="telefone" name="telefone" class="input-perfil" value="<%= user.Telefone || '' %>"
                        disabled />
                </div>
                <!-- Card de curso/projeto -->
                <div class="perfil-card">
                    <h3>Projeto</h3>
                    <p><%= user.Projeto || 'Nenhum' %></p>
                    <h3>Curso</h3>
                    <p><%= (turma && turma.Curso) ? turma.Curso : 'A definir' %></p>
                </div>
                <!-- Card de status e matrícula -->
                <div class="perfil-card perfil-card-senha">
                    <h3 class="perfil-label">Senha</h3>
                    <input type="password" id="senha-usuario" name="senha-usuario" class="input-perfil" value="<%= user.Senha %>"
                        disabled autocomplete="off" />
                    <button type="button" id="btn-trocar-senha" class="btn-trocar-senha" style="display: none;">Trocar
                        senha</button>
                    <div id="troca-senha-area" style="display:none;">
                        <input type="password" id="senha-atual-input" name="senha-atual-input" class="input-perfil"
                            placeholder="Digite sua senha atual" autocomplete="current-password" />
                        <input type="password" id="nova-senha" name="nova-senha" class="input-perfil"
                            placeholder="Nova senha" autocomplete="new-password" />
                        <input type="password" id="confirma-senha" name="confirma-senha" class="input-perfil"
                            placeholder="Confirmar nova senha" autocomplete="new-password" />
                        <span id="senha-erro" class="senha-erro"></span>
                    </div>
                </div>
                <div style="grid-column:1/3;text-align:right;padding-top:16px;">
                    <button type="button" id="btn-editar" class="btn-editar">Editar</button>
                    <button type="button" id="btn-cancelar" class="btn-cancelar" style="display:none;">Cancelar</button>
                    <button type="submit" id="btn-salvar" class="btn-salvar" style="display:none;">Salvar
                        alterações</button>
                </div>
            </form>
            </main>
            <script src="javascript/sidebar.js"></script>
            <script src="javascript/perfil.js"></script>
</body>

</html>

<!DOCTYPE html>
<html lang="pt-br">

<head>
    <link href='https://cdn.boxicons.com/fonts/basic/boxicons.min.css' rel='stylesheet'>
  <link rel="stylesheet" href="css/sidebar.css">
  <link rel="stylesheet" href="css/perfil.css">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Perfil</title>
</head>
<body class="sidebar-collapsed">
    <%- include('partials/navbar') %>

    <main class="content perfil-content" style="padding:50px;">
    <h1>Seu perfil</h1>
    <div class="perfil-grid">
            <!-- Card principal com avatar e dados básicos -->
            <div class="perfil-card">
                <div class="perfil-avatar">
                    <img src="imgs/ETEC_POA.jpg" alt="Avatar do usuário" />
                </div>
                <div class="perfil-info">
                    <h2>Nome do Usuário</h2>
                    <p>Data de Nascimento: 10/02/2006</p>
                    <p>RM: 00000</p>
                </div>
            </div>
            <!-- Card de contato -->
            <div class="perfil-card">
                <h3>Contato</h3>
                <p>Email: usuario@email.com</p>
                <p>Telefone: (11) 99999-9999</p>
            </div>
            <!-- Card de curso/projeto -->
            <div class="perfil-card">
                <h3>Curso</h3>
                <p>Informática para Internet</p>
                <h3>Projeto</h3>
                <p>Portal Acadêmico</p>
            </div>
            <!-- Card de status e matrícula -->
            <div class="perfil-card">
                <h3>Status</h3>
                <p>Ativo</p>
                <h3>Data de Matrícula</h3>
                <p>01/02/2022</p>
                <h3>Idade</h3>
                <p>19 anos</p>
            </div>
        </div>
    </main>
  <script src="javascript/sidebar.js"></script>
</body>
</html>
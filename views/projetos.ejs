<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <link rel="stylesheet" href="css/rightbar.css">
  <link rel="stylesheet" href="css/sidebar.css">
  <link rel="stylesheet" href="css/projetos.css">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Projetos</title>
</head>
<body class="sidebar-collapsed">
  <%- include('navbar') %>
  <div class="container">
    <!-- Card 1 -->
    <div class="card">
      <img src="https://via.placeholder.com/400x300" alt="Projeto 1">
      <div class="card-content">
        <h3>Projeto 1</h3>
        <p>Resumo rápido do projeto.</p>
        <span class="btn_vermais" onclick="toggleCard(this)">Ver mais</span>
        <div class="extra-content">
          <p>
            Aqui está a versão expandida do projeto 1.  
            Você pode descrever em detalhes, adicionar prints, links e tudo o que quiser.  
            O card agora se transforma para mostrar o conteúdo completo.
          </p>
        </div>
      </div>
    </div>

    <!-- Card 2 -->
    <div class="card">
      <img src="https://via.placeholder.com/400x300" alt="Projeto 2">
      <div class="card-content">
        <h3>Projeto 2</h3>
        <p>Pequena descrição inicial.</p>
        <span class="btn_vermais" onclick="toggleCard(this)">Ver mais</span>
        <div class="extra-content">
          <p>
            Detalhes expandidos do projeto 2.  
            Explicação técnica, história de criação e resultados.
          </p>
        </div>
      </div>
    </div>
  </div>

<%- include('rightbar') %>

<script src="javascript/rightbar.js"></script>
  <script src="javascript/projetos.js"></script>
<script src="javascript/sidebar.js"></script>
</body>
</html>
      </div>

      <div class="terms-actions">
        <label class="terms-checkbox">
          <input id="terms-checkbox" type="checkbox">
          Aceito os Termos de Uso
        </label>
        <div id="terms-warning" class="terms-warning" aria-live="polite"></div>
        <div class="terms-buttons">
          <button id="decline-terms" type="button" class="btn-decline">Recusar</button>
          <button id="accept-terms" type="button" class="btn-accept">Aceitar e Entrar</button>
        </div>
      </div>
    </div>
  </div>

      <!-- Arquivo Javascript -->
      <script src="javascript/login.js"></script>
</body>

</html>